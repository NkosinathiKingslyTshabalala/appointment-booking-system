{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "es2022",
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "prisma.config.ts"]
}